# Spot credentials (secrets).
SPOT_USERNAME=user
SPOT_PASSWORD=changeme

# Optional override if you want a different config file path.
# CONFIG_PATH=config/formant-spot-adapter.json
# Per-stream enable/disable lives in JSON `streamControls`; there is no env override for that table.

# Optional overrides (normally configured in JSON).
# SPOT_HOST=192.168.50.3
# FORMANT_AGENT_TARGET=localhost:5501
# ARM_PRESENT=true
# ESTOP_BUTTON_STREAM=E-Stop
# RECOVER_BUTTON_STREAM=Recover
# WALK_BUTTON_STREAM=Walk
# STAIRS_BUTTON_STREAM=Stairs
# CRAWL_BUTTON_STREAM=Crawl
# RESET_ARM_BUTTON_STREAM=Reset Arm
# ARM_RAISE_BUTTON_STREAM=Arm Raise
# STATEFUL_MODE_STREAM=spot.mode_state
# TELEOP_IDLE_TIMEOUT_MS=1000
# TWIST_DEADBAND=0.08
# MAX_VX_MPS=0.8
# MAX_VY_MPS=0.5
# MAX_WZ_RPS=1.2
# MAX_BODY_PITCH_RAD=0.25
# TRANSLATION_RESPONSE_CURVE=1.4
# ROTATION_RESPONSE_CURVE=1.2
# LINEAR_ACCEL_LIMIT_MPS2=0.8
# STRAFE_ACCEL_LIMIT_MPS2=0.6
# ANGULAR_ACCEL_LIMIT_RPS2=1.5
# BODY_PITCH_RATE_LIMIT_RADPS=0.5
# ARM_HOLD_INTERVAL_MS=2500
# GRAPHNAV_STORE_DIR=data/graphnav
# WAYPOINT_TEXT_STREAM=spot.waypoints
# MAPS_TEXT_STREAM=spot.maps
# SURROUND_CAMERA_FPS=15
# SURROUND_CAMERA_POLL_HZ=15
# FRONT_LEFT_CAMERA_SOURCE=frontleft_fisheye_image
# FRONT_RIGHT_CAMERA_SOURCE=frontright_fisheye_image
# FRONT_IMAGE_STREAM_NAME=spot.front.image
# FRONT_IMAGE_FPS=15
# FRONT_IMAGE_POLL_HZ=15
# FRONT_IMAGE_ROLL_DEGREES=90
# If unset, the adapter auto-selects the best front stitch roll per robot/calibration.
# RIGHT_CAMERA_ROTATE_180=true
# LOCALIZATION_IMAGE_STREAM_NAME=spot.localization.graphnav.image
# LOCALIZATION_IMAGE_FPS=15
# LOCALIZATION_IMAGE_POLL_HZ=2
# GRAPHNAV_GLOBAL_LOCALIZATION_STREAM=spot.localization.graphnav.global
# GRAPHNAV_GLOBAL_LOCALIZATION_HZ=2
# GRAPHNAV_MAP_STREAM=spot.map.graphnav
# GRAPHNAV_METADATA_STREAM=spot.graphnav.metadata
# GRAPHNAV_OVERLAY_STREAM=spot.graphnav.overlay
# GRAPHNAV_NAV_STATE_STREAM=spot.nav.state
# GRAPHNAV_MAP_IMAGE_STREAM_NAME=spot.localization.graphnav.global.image
# GRAPHNAV_MAP_IMAGE_FPS=15
# GRAPHNAV_MAP_IMAGE_POLL_HZ=2
# GRAPHNAV_COMMAND_TIMEOUT_SEC=60
